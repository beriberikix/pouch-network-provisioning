config POUCH_PROV_FAKE_WIFI
	bool "Fake (simulated) Wi-Fi driver for tests"
	depends on NETWORKING
	select WIFI
	select WIFI_USE_NATIVE_NETWORKING
	select NET_L2_ETHERNET
	select NET_L2_WIFI_MGMT
	help
	  A hardware-less Wi-Fi offload network interface for native_sim. It
	  answers scan/connect/iface_status with programmable, deterministic
	  results so the provisioning handlers can be exercised in simulation,
	  including failure injection. Test-only.

if POUCH_PROV_FAKE_WIFI

config POUCH_PROV_FAKE_WIFI_MAX_AP
	int "Maximum number of canned scan APs"
	default 8

endif
